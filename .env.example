# TalkGuru — Шаблон переменных окружения
# Скопируйте в .env и заполните значения

# ====== TELEGRAM ======
BOT_TOKEN=                    # Токен бота от @BotFather

# ====== PYROGRAM (Client API) ======
PYROGRAM_API_ID=              # API ID из https://my.telegram.org
PYROGRAM_API_HASH=            # API Hash из https://my.telegram.org

# ====== БАЗА ДАННЫХ (Supabase) ======
SUPABASE_URL=                 # https://xxx.supabase.co
# ВАЖНО: используйте service_role ключ (Settings → API → service_role key)
# НЕ anon key! RLS включён — anon ключ не имеет доступа.
SUPABASE_KEY=

# ====== ШИФРОВАНИЕ СЕССИЙ ======
# Сгенерируйте ключ командой:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=

# ====== x402gate.io (оплата USDC на Base) ======
EVM_PRIVATE_KEY=              # Приватный ключ кошелька Base (hex, с 0x или без)

# ====== ОТЛАДКА ======
DEBUG_PRINT=False             # True для подробного логирования
LOG_TO_FILE=False             # True для записи summary логов OpenRouter в logs/
